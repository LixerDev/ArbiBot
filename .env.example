# ================================
# ArbiBot Configuration
# ================================

# Discord Webhook URL (optional — alerts when profitable arb found)
DISCORD_WEBHOOK_URL=

# ================================
# Scan Settings
# ================================

# Quote size in USD (larger = more realistic but more slippage)
SCAN_AMOUNT_USD=1000

# Minimum net profit (USD) to trigger an alert
MIN_PROFIT_USD=0.50

# Minimum spread percentage to show in dashboard (0 = show all)
MIN_SPREAD_PCT=0.0

# Scan refresh interval in seconds
REFRESH_INTERVAL=5

# Only show profitable opportunities in watch mode
PROFITABLE_ONLY=false

# ================================
# Fee Settings
# ================================

# Raydium AMM fee in basis points (1 bps = 0.01%)
RAYDIUM_AMM_FEE_BPS=25

# Raydium CLMM fee in basis points
RAYDIUM_CLMM_FEE_BPS=4

# Orca Whirlpool fee in basis points
ORCA_FEE_BPS=30

# Estimated gas cost per transaction in USD
GAS_COST_USD=0.001

# Number of transactions needed (buy + sell = 2)
TXS_PER_ARB=2

# ================================
# Alert Settings
# ================================

# Cooldown between alerts for the same pair (minutes)
ALERT_COOLDOWN_MINUTES=5

# ================================
# Token Pairs to Monitor
# Comma-separated: BASE/QUOTE
# ================================
WATCH_PAIRS=SOL/USDC,JUP/USDC,BONK/USDC,WIF/USDC,mSOL/USDC,PYTH/USDC,JTO/USDC

# ================================
# Logging
# ================================
LOG_LEVEL=INFO
